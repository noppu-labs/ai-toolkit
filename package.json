{
  "type": "module",
  "workspaces": [
    "site"
  ],
  "scripts": {
    "coverage-ci": "vitest run --coverage",
    "fuzz": "JAZZER_FUZZ=1 jest -t parseSkillArg && JAZZER_FUZZ=1 jest -t hashFiles",
    "fuzz:regression": "jest",
    "lint": "biome check . && markdownlint-cli2",
    "lint:fix": "biome check --write . && markdownlint-cli2 --fix",
    "sync": "tsx scripts/sync.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@fast-check/vitest": "^0.4.1",
    "@jazzer.js/core": "^4.0.0",
    "@jazzer.js/jest-runner": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "markdownlint-cli2": "^0.23.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
