{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "es2025",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["es2025", "dom", "dom.iterable"],
    "types": ["vite/client", "node"],
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "scripts", "vite.config.ts"]
}
